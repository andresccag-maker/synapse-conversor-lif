#!/bin/sh
# AppRun — punto de entrada del AppImage de SYN APSE — Conversor LIF.
# Lanza el binario PyInstaller (onedir) que vive bajo usr/.
HERE="$(dirname "$(readlink -f "$0")")"
export PATH="$HERE/usr:$HERE/usr/bin:$PATH"
export XDG_DATA_DIRS="$HERE/usr/share:${XDG_DATA_DIRS:-/usr/local/share:/usr/share}"
exec "$HERE/usr/SYN_APSE_Conversor_LIF" "$@"
